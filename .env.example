# OPENAI_API_KEY=sk-your-api-key

# Model/runtime
# MODEL_ID=dataautogpt3/OpenDalle
# TORCH_DTYPE=bf16
# MAX_CONCURRENT=1

# Defaults for generation
# DEFAULT_STEPS=20
# DEFAULT_GUIDANCE=7.0

# Input guard rails
# ALLOWED_SIZES=512x512,768x768,1024x1024
# MAX_PIXELS=1048576
# REQUIRE_MULTIPLE_OF=8

# Optional runtime features
# ENABLE_XFORMERS=0
# TORCH_COMPILE=0
# WARMUP=1

# Idle GPU memory management (seconds)
# Set to 0 (or negative) to disable idle unload behavior.
# IDLE_UNLOAD_SECONDS=3600

# Server port (used by `python app.py` path; run.sh also accepts CLI args)
# PORT=8000
