# Mandatory
OPENAI_API_KEY=replace-with-a-strong-token

# Optional model + runtime
# MODEL_ID=dataautogpt3/OpenDalle
# TORCH_DTYPE=bf16
# MAX_CONCURRENT=1

# Optional generation defaults
# DEFAULT_STEPS=20
# DEFAULT_GUIDANCE=7.0
# STREAM_FORMAT=jpeg

# Optional size policy
# ALLOWED_SIZES=512x512,768x768,1024x1024
# MAX_PIXELS=1048576
# REQUIRE_MULTIPLE_OF=8

# Optional performance toggles
# ENABLE_XFORMERS=0
# TORCH_COMPILE=0
# WARMUP=1

# Optional app port (used only by `python app.py` path)
# PORT=8000
