OPENAI_API_KEY=sk-your-api-key

# Model/runtime
MODEL_ID=dataautogpt3/OpenDalle # valeur par défaut
TORCH_DTYPE=bf16 # valeur par défaut
MAX_CONCURRENT=1 # valeur par défaut

# Defaults for generation
DEFAULT_STEPS=20 # valeur par défaut
DEFAULT_GUIDANCE=7.0 # valeur par défaut

# Input guard rails
ALLOWED_SIZES=512x512,768x768,1024x1024 # valeur par défaut
MAX_PIXELS=1048576 # valeur par défaut
REQUIRE_MULTIPLE_OF=8 # valeur par défaut

# Optional runtime features
ENABLE_XFORMERS=0 # valeur par défaut
TORCH_COMPILE=0 # valeur par défaut
WARMUP=1 # valeur par défaut

# Idle GPU memory management (seconds)
# Set to 0 (or negative) to disable idle unload behavior.
IDLE_UNLOAD_SECONDS=3600 # valeur par défaut (1h)

# Server port (used by `python app.py` path; run.sh also accepts CLI args)
PORT=8000 # valeur par défaut
